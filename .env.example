# BrasilZ Leaderboard — environment variables template
# Copy to .env and fill with strong secrets. Never commit real .env to git.
# Generate strong values:
#   openssl rand -base64 24      → DB_PASSWORD
#   openssl rand -hex 32         → INGEST_API_KEY (same as BZ_PortalConfig.API_KEY in mod)
#   openssl rand -hex 32         → JWT_SECRET

DB_PASSWORD=change_me_to_strong_random
INGEST_API_KEY=change_me_64_hex_random
JWT_SECRET=change_me_64_hex_random
ADMIN_USER=admin
ADMIN_PASSWORD=change_me_admin_password
